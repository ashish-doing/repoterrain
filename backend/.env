# RepoTerrain — Environment Variables
# Copy to .env and fill in your values

# ── Google Cloud ──────────────────────────────────────────────────────────────
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1

# ── GitLab ────────────────────────────────────────────────────────────────────
# Personal access token with: api, read_repository, write_repository
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# ── GitLab MCP Server URL (optional — uses hosted GitLab MCP by default) ─────
# GITLAB_MCP_URL=https://gitlab.com/-/mcp

# ── App ───────────────────────────────────────────────────────────────────────
PORT=8000
ENV=development
